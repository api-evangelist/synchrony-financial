  "info": {
    "_postman_id": "921a0fd1-86ca-4638-8303-2e1481820b94",
    "name": "Synchrony Financial Quickscreen Apply API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Synchrony Financial Quickscreen Apply API is a preapproval engine that allows merchants to offer instant credit decisions using only a customer's name and address. It runs a soft credit check and returns a real-time decision, enabling seamless credit offering within the shopping experience. The mApply feature allows customers to securely apply for credit on mobile devices and instantly access their approved credit line.",
      "type": "text/plain"
    }
  }
